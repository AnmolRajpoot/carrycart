<%- include("partials/header", { title: "CarryCart | Cart" }) %>

<%- include("partials/navbar", { user: user }) %>

<div class="max-w-7xl mx-auto px-6 py-10">

    <h1 class="text-4xl font-bold mb-8">
        Shopping Cart
    </h1>

    <% if(cart.length === 0){ %>

        <div class="bg-white rounded-3xl shadow-md p-16 text-center">

            <i class="ri-shopping-cart-line text-7xl text-gray-300"></i>

            <h2 class="text-3xl font-bold mt-6">
                Your Cart is Empty
            </h2>

            <p class="text-gray-500 mt-3">
                Looks like you haven't added any products yet.
            </p>

            <a
                href="/shop"
                class="inline-block mt-8 bg-blue-600 hover:bg-blue-700 text-white px-8 py-4 rounded-xl font-semibold transition"
            >
                Continue Shopping
            </a>

        </div>

    <% } else { %>

    <div class="grid lg:grid-cols-3 gap-8">

        <!-- ================= Left Side ================= -->

        <div class="lg:col-span-2 space-y-6">

            <% let total = 0; %>

            <% cart.forEach(product => { %>

                <% total += product.price; %>

                <div class="bg-white rounded-3xl shadow-md p-6 flex gap-6 items-center">

                    <!-- Image -->

                    <div
                        class="w-36 h-36 rounded-2xl flex items-center justify-center"
                        style="background:<%= product.panelcolor %>;"
                    >

                        <img
                            src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                            alt="<%= product.name %>"
                            class="max-h-28 object-contain"
                        >

                    </div>

                    <!-- Product Details -->

                    <div class="flex-1">

                        <h2
                            class="text-2xl font-bold"
                            style="color:<%= product.textcolor %>;"
                        >
                            <%= product.name %>
                        </h2>

                        <p class="text-gray-500 mt-2">
                            Premium CarryCart Product
                        </p>

                        <% if(product.discount > 0){ %>

                            <span class="inline-block mt-3 bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm">

                                <%= product.discount %>% OFF

                            </span>

                        <% } %>

                    </div>

                    <!-- Price -->

                    <div class="text-right">

                        <h2 class="text-3xl font-bold">

                            ₹ <%= product.price %>

                        </h2>

                        <div class="flex justify-end mt-5 gap-3">

                            <!-- Quantity -->

                            <button
                                class="w-10 h-10 rounded-full border hover:bg-gray-100"
                                disabled
                            >
                                -
                            </button>

                            <span class="w-10 flex items-center justify-center">

                                1

                            </span>

                            <button
                                class="w-10 h-10 rounded-full border hover:bg-gray-100"
                                disabled
                            >
                                +
                            </button>

                        </div>

                        <!-- Remove -->

                        <button
                            class="text-red-500 hover:text-red-700 mt-4"
                            disabled
                        >

                            <i class="ri-delete-bin-line text-xl"></i>

                        </button>

                    </div>

                </div>

            <% }) %>

        </div>

        <!-- ================= Order Summary ================= -->

        <div>

            <div class="bg-white rounded-3xl shadow-lg p-8 sticky top-28">

                <h2 class="text-3xl font-bold mb-8">

                    Order Summary

                </h2>

                <div class="flex justify-between text-lg mb-4">

                    <span>

                        Products

                    </span>

                    <span>

                        <%= cart.length %>

                    </span>

                </div>

                <div class="flex justify-between text-lg mb-4">

                    <span>

                        Delivery

                    </span>

                    <span class="text-green-600">

                        FREE

                    </span>

                </div>

                <hr class="my-6">

                <div class="flex justify-between text-2xl font-bold">

                    <span>

                        Total

                    </span>

                    <span>

                        ₹ <%= total %>

                    </span>

                </div>

                <button
                    class="w-full mt-8 bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-xl font-semibold transition"
                >

                    <i class="ri-secure-payment-line mr-2"></i>

                    Proceed to Checkout

                </button>

                <a
                    href="/shop"
                    class="block text-center mt-5 text-blue-600 hover:underline"
                >

                    Continue Shopping

                </a>

            </div>

        </div>

    </div>

    <% } %>

</div>

<%- include("partials/footer") %>