<%- include("partials/header", { title: "CarryCart | Welcome" }) %>

<div class="min-h-screen flex">

    <!-- ================= LEFT SECTION ================= -->

    <div
        class="hidden lg:flex w-1/2 bg-gradient-to-br from-blue-700 to-indigo-900 text-white p-16 flex-col justify-between"
    >

        <div>

            <div class="flex items-center gap-3 mb-12">

                <i class="ri-shopping-bag-4-fill text-5xl"></i>

                <h1 class="text-5xl font-bold">

                    CarryCart

                </h1>

            </div>

            <h2 class="text-5xl font-bold leading-tight">

                Shop Smarter.

                <br>

                Live Better.

            </h2>

            <p class="mt-8 text-lg text-blue-100 leading-8">

                CarryCart is a modern shopping platform built with
                Node.js, Express.js, MongoDB and EJS.

            </p>

        </div>

        <div class="space-y-6">

            <div class="flex items-center gap-4">

                <i class="ri-truck-line text-3xl"></i>

                <span class="text-lg">

                    Fast Delivery

                </span>

            </div>

            <div class="flex items-center gap-4">

                <i class="ri-secure-payment-line text-3xl"></i>

                <span class="text-lg">

                    Secure Payments

                </span>

            </div>

            <div class="flex items-center gap-4">

                <i class="ri-customer-service-2-line text-3xl"></i>

                <span class="text-lg">

                    24 × 7 Customer Support

                </span>

            </div>

        </div>

    </div>

    <!-- ================= RIGHT SECTION ================= -->

    <div
        class="w-full lg:w-1/2 flex items-center justify-center bg-gray-100 p-8"
    >

        <div
            class="bg-white rounded-3xl shadow-xl w-full max-w-md p-10"
        >

            <div class="text-center mb-8">

                <h2 class="text-3xl font-bold">

                    Welcome Back

                </h2>

                <p class="text-gray-500 mt-2">

                    Login to continue shopping

                </p>

            </div>

            <% if(error && error.length){ %>

                <div
                    class="bg-red-100 text-red-700 p-3 rounded-xl mb-5"
                >

                    <%= error %>

                </div>

            <% } %>

            <!-- ================= LOGIN ================= -->

            <form
                action="/users/login"
                method="POST"
                class="space-y-5"
            >

                <input
                    type="email"
                    name="email"
                    placeholder="Email Address"
                    required
                    class="w-full border rounded-xl p-4 focus:ring-2 focus:ring-blue-500 outline-none"
                >

                <input
                    type="password"
                    name="password"
                    placeholder="Password"
                    required
                    class="w-full border rounded-xl p-4 focus:ring-2 focus:ring-blue-500 outline-none"
                >

                <button
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-xl font-semibold transition"
                >

                    <i class="ri-login-box-line mr-2"></i>

                    Login

                </button>

            </form>

            <!-- Divider -->

            <div class="flex items-center my-8">

                <div class="flex-1 border-t"></div>

                <span class="mx-4 text-gray-400">

                    OR

                </span>

                <div class="flex-1 border-t"></div>

            </div>

            <!-- ================= REGISTER ================= -->

            <h3
                class="text-xl font-semibold mb-5"
            >

                Create New Account

            </h3>

            <form
                action="/users/register"
                method="POST"
                class="space-y-4"
            >

                <input
                    type="text"
                    name="fullname"
                    placeholder="Full Name"
                    required
                    class="w-full border rounded-xl p-4"
                >

                <input
                    type="email"
                    name="email"
                    placeholder="Email Address"
                    required
                    class="w-full border rounded-xl p-4"
                >

                <input
                    type="password"
                    name="password"
                    placeholder="Password"
                    required
                    class="w-full border rounded-xl p-4"
                >

                <button
                    class="w-full bg-green-600 hover:bg-green-700 text-white py-4 rounded-xl font-semibold transition"
                >

                    <i class="ri-user-add-line mr-2"></i>

                    Create Account

                </button>

            </form>

        </div>

    </div>

</div>

<%- include("partials/footer") %>