<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Product</title>
</head>
<body>

<h1>Create Product</h1>

<form
    action="/owners/product/create"
    method="POST"
    enctype="multipart/form-data"
>

    <input
        type="text"
        name="name"
        placeholder="Product Name"
        required
    >

    <input
        type="number"
        name="price"
        placeholder="Price"
        required
    >

    <input
        type="number"
        name="discount"
        placeholder="Discount"
    >

    <input
        type="text"
        name="bgcolor"
        placeholder="Background Color"
    >

    <input
        type="text"
        name="panelcolor"
        placeholder="Panel Color"
    >

    <input
        type="text"
        name="textcolor"
        placeholder="Text Color"
    >

    <input
        type="text"
        name="image"
        placeholder="Image URL"
    >

    <button>Create Product</button>

</form>

</body>
</html>